# AI CUP 2026 deliverable .gitignore
# Tracks code + README + reference submission only.
# Data and large caches are user-provided / auto-generated.

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.Python
*.so

# Data (user must download from competition platform)
data/train.csv
data/test_new.csv
data/test.csv
data/external/shuttleset22/train.csv

# Cache (auto-generated by training)
cache/*.npz
cache/*.pt
cache/*/

# Generated submissions (only reference 2026-05-25 0.4472604 baseline is tracked)
submissions/submission_*.csv
!submissions/submission_v27_oldleak_20260525_0103.csv

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp
