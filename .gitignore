# AI CUP 2026 deliverable .gitignore
# Tracks code + README + reference submission only.
# Data and large caches are user-provided / auto-generated.

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.Python
*.so

# Data files are now BUNDLED for direct reproducibility (totals ~8 MB):
# - data/train.csv          (主辦提供)
# - data/test_new.csv       (主辦提供)
# - data/test.csv           (主辦 2026-05-21 公告開放 Reference_Only_Old_Test_Data)
# - data/external/shuttleset22/train.csv  (CoachAI Projects, 已開源)

# Cache (auto-generated by training, ~1.1 GB total — NOT bundled to stay within GitHub limits)
cache/*.npz
cache/*.pt
cache/*/

# Generated submissions (only reference 2026-05-25 0.4472604 baseline is tracked)
submissions/submission_*.csv
!submissions/submission_v27_oldleak_20260525_0103.csv

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp
